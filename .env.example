# ============================================================
# Leo Quiz Pipeline — Environment Variables
# Copy this file to .env and fill in your keys.
# ============================================================

# ── REQUIRED: AI Content Generation ─────────────────────────
# Google Gemini API key — generates quiz questions, fun facts,
# image prompts, and platform metadata (titles, descriptions, tags).
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── REQUIRED: Voice Narration ───────────────────────────────
# ElevenLabs API key — converts quiz text to kid-friendly speech.
# Free tier gives 10,000 chars/month. https://elevenlabs.io
ELEVENLABS_API_KEY=

# !! CRITICAL — #1 BLOCKER !!
# ElevenLabs Voice ID — identifies WHICH voice to use for narration.
# Without this, narration SILENTLY SKIPS (no error, just silent video).
# Find yours at: ElevenLabs dashboard → Voices → click voice → copy ID
# Example: "pNInz6obpgDQGcFmaJgB" (Adam voice)
ELEVENLABS_VOICE_ID=

# ── OPTIONAL: Stock Photos ──────────────────────────────────
# Pexels API key — fetches real photos for speed quiz format.
# Only needed for "speed" format videos. Free at: https://www.pexels.com/api/
# If missing, pipeline falls back to AI-generated images.
PEXELS_API_KEY=

# ── OPTIONAL: Vercel Blob Upload ────────────────────────────
# Used by uploader.py to push finished videos/thumbnails to Vercel Blob.
# Only needed when running locally and wanting to upload to dashboard.
# In GitHub Actions, this is set via repository secrets instead.
# Get from: Vercel dashboard → Storage → Blob → Tokens
BLOB_READ_WRITE_TOKEN=

# ── GitHub Actions Secrets (not needed locally) ─────────────
# These are configured as GitHub repository secrets, NOT in .env.
# Listed here for documentation only:
#
# DASHBOARD_URL           — Full URL of the dashboard (e.g. https://leo-quiz.vercel.app)
# DASHBOARD_WEBHOOK_SECRET — Shared secret for pipeline→dashboard webhook auth
